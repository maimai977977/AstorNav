---
// src/layouts/BaseLayout.astro
import '../styles/global.css'
import NavCard from '../components/NavCard.astro';
import navData from '../data/Navdata.json';

export interface Props {
  title?: string;
}

const { title = "MaiMaiNav" } = Astro.props;

// 提取所有不重复的分类（过滤掉空值），并添加"全部"
const categories = ['全部', ...new Set(navData.map(item => item.category).filter(Boolean))];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Astro + Tailwind 布局示例" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>
  <body class="bg-gradient-to-br from-slate-50 via-white to-slate-100 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 text-slate-900 dark:text-slate-100 min-h-screen">
    <div x-data="{ sidebarOpen: true }" class="flex flex-col min-h-screen">
      
      <!-- 顶部导航栏 -->
      <header class="fixed top-0 left-0 right-0 z-30 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border-b border-slate-200/50 dark:border-slate-700/50 shadow-sm">
        <div class="flex items-center justify-between h-16 px-4 lg:px-6">
          <div class="flex items-center gap-3">
            <button @click="sidebarOpen = !sidebarOpen" class="p-2 rounded-xl text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all group">
              <svg x-show="!sidebarOpen" class="w-5 h-5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
              <svg x-show="sidebarOpen" class="w-5 h-5 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4L4 8l4 4" /></svg>
            </button>
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center shadow-lg shadow-blue-500/25">
                <span class="text-white font-bold text-sm">M</span>
              </div>
              <span class="text-xl font-bold bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 bg-clip-text text-transparent">MaiMaiNav</span>
            </div>
            <span class="hidden md:inline text-sm text-slate-500 dark:text-slate-400 italic" id="dailyQuote"></span>
          </div>
          
          <div class="flex items-center gap-2">
            <!-- 夸克网盘资源入口按钮 -->
            <a href="/AstroNav/table" class="p-2 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-all group relative" title="夸克网盘资源库">
              <svg class="w-5 h-5 text-slate-600 dark:text-slate-400 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2 1.5 4 4 4h8c2.5 0 4-2 4-4V7M4 7h16M4 7l4-4h8l4 4" />
              </svg>
              <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity text-xs bg-slate-800 text-white px-2 py-1 rounded whitespace-nowrap pointer-events-none">
                网盘资源
              </div>
            </a>
            
            <!-- 文件夹视图入口按钮 -->
            <a href="/AstroNav/folder" class="p-2 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-all group relative" title="文件夹视图">
              <svg class="w-5 h-5 text-slate-600 dark:text-slate-400 group-hover:text-purple-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
              </svg>
              <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity text-xs bg-slate-800 text-white px-2 py-1 rounded whitespace-nowrap pointer-events-none">
                文件夹
              </div>
            </a>
            
            <!-- 搜索框 -->
            <div class="relative hidden sm:block">
              <input
                type="text"
                id="searchInput"
                placeholder="搜索导航..."
                class="w-48 lg:w-64 pl-9 pr-4 py-2 text-sm bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-transparent transition-all placeholder:text-slate-400"
                autocomplete="off"
              />
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>

            <!-- QQ头像 -->
            <div class="group relative">
              <img
                id="qqAvatar"
                src="https://q1.qlogo.cn/g?b=qq&nk=80000000&s=100"
                alt="QQ头像"
                class="w-9 h-9 rounded-full border-2 border-blue-500 shadow-md transition-transform duration-500 hover:rotate-180 cursor-pointer hover:scale-110"
                onerror="this.src='https://placehold.co/100x100/3b82f6/white?text=QQ'"
              />
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-full mt-1 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none text-xs bg-slate-800 text-white px-2 py-1 rounded whitespace-nowrap">
                点击切换
              </div>
            </div>
          </div>
        </div>
      </header>

<!-- 主体布局 -->
      <div class="flex flex-1 pt-16">
        <!-- 侧边栏 -->
        <aside
          x-show="sidebarOpen"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="-translate-x-full"
          x-transition:enter-end="translate-x-0"
          x-transition:leave="transition ease-in duration-200"
          x-transition:leave-start="translate-x-0"
          x-transition:leave-end="-translate-x-full"
          class="fixed left-0 top-16 z-20 w-64 bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border-r border-slate-200/50 dark:border-slate-700/50 h-[calc(100vh-4rem)] overflow-y-auto shadow-xl"
        >
          <nav class="p-3 space-y-0.5">
            <div class="mb-3 px-3 py-2">
              <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">导航分类</p>
            </div>
            {categories.map(cat => {
              const hash = cat === '全部' ? '' : cat;
              return (
                <a
                  href={hash ? `#${encodeURIComponent(hash)}` : '#'}
                  class="nav-link flex items-center gap-3 px-3 py-2 text-slate-700 dark:text-slate-300 rounded-xl hover:bg-slate-100 dark:hover:bg-slate-800 transition-all group"
                  data-category={cat}
                >
                  <span class="w-2 h-2 rounded-full bg-gradient-to-r from-blue-500 to-purple-500 opacity-0 group-hover:opacity-100 transition-opacity"></span>
                  <span class="text-sm font-medium">{cat}</span>
                </a>
              );
            })}
          </nav>
        </aside>

        <!-- 右侧内容区域 -->
        <main 
          class="flex-1 p-6 overflow-x-auto transition-all duration-300"
          :class="{ 'lg:pl-64': sidebarOpen, 'lg:pl-6': !sidebarOpen }"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="card-grid">
            {navData.map(item => (
              <div class="card-item" data-category={item.category}>
                <NavCard 
                  id={item.id as number}
                  title={item.title as string}
                  description={item.description as string}
                  tags={item.tags as string[]}
                  status={item.status as "online" | "offline"}
                  url={item.url as string}
                  image={item.image as string}
                />
              </div>
            ))}
          </div>
        </main>
      </div>
    ))}
  </div>
</main>
      </div>

<footer class="relative mt-12 overflow-hidden bg-gradient-to-r from-slate-900 via-slate-800 to-slate-900 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950 border-t border-slate-700/50">
  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-blue-500/5 to-transparent -translate-x-full animate-[shimmer_4s_infinite]"></div>
  
  <div class="container mx-auto px-4 py-6 relative z-10">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center">
          <span class="text-white font-bold text-sm">M</span>
        </div>
        <div>
          <span class="text-lg font-black bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">
            MaiMaiNav
          </span>
          <p class="text-xs text-slate-400 mt-0.5">高效导航 · 简洁生活</p>
        </div>
      </div>
      
      <div class="flex gap-2">
        <a href="#" class="group w-9 h-9 rounded-xl bg-white/5 backdrop-blur-sm flex items-center justify-center hover:bg-blue-500 transition-all duration-300 hover:scale-110" title="GitHub">
          <svg class="w-4 h-4 text-slate-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
          </svg>
        </a>
        <a href="#" class="group w-9 h-9 rounded-xl bg-white/5 backdrop-blur-sm flex items-center justify-center hover:bg-purple-500 transition-all duration-300 hover:scale-110" title="邮箱">
          <svg class="w-4 h-4 text-slate-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
          </svg>
        </a>
      </div>
    </div>
    
    <div class="mt-4 pt-4 border-t border-slate-700/50">
      <p class="text-xs text-slate-400 leading-relaxed">
        © 2026 MaiMaiNav · 数据仅供学习参考 · 本站不储存、复制、传播任何文件
        <a href="mailto:maimai977977@gmail.com" class="text-blue-400 hover:text-blue-300 transition-colors">联系我们</a>
      </p>
    </div>
  </div>
  
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-blue-500 to-transparent"></div>
</footer>


 <!-- 返回顶部按钮 -->
<div id="back-to-top" class="fixed bottom-6 right-6 z-30 opacity-0 invisible transition-all duration-300 translate-y-4">
  <button 
    onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    class="group p-3 bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 hover:-translate-y-1"
    aria-label="返回顶部"
  >
    <svg class="w-5 h-5 transition-transform duration-300 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>
</div>
<script>
  // ========== 分类 + 搜索联合过滤 ==========
  function filterAndHighlight() {
    let hash = window.location.hash.slice(1);
    hash = decodeURIComponent(hash);
    const currentCategory = hash || '全部';
    
    const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
    const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
    
    const cards = document.querySelectorAll('.card-item');
    cards.forEach(card => {
      const cardCategory = card.getAttribute('data-category');
      const categoryMatch = (currentCategory === '全部' || cardCategory === currentCategory);
      
      let searchMatch = true;
      if (searchTerm) {
        const titleEl = card.querySelector('h3');
        const descEl = card.querySelector('p');
        const title = titleEl ? titleEl.textContent.toLowerCase() : '';
        const desc = descEl ? descEl.textContent.toLowerCase() : '';
        searchMatch = title.includes(searchTerm) || desc.includes(searchTerm);
      }
      
      (card as HTMLElement).style.display = (categoryMatch && searchMatch) ? '' : 'none';
    });
    
    const links = document.querySelectorAll('.nav-link');
    links.forEach(link => {
      const linkCategory = link.getAttribute('data-category');
      if (linkCategory === currentCategory) {
        link.classList.add('bg-slate-100', 'dark:bg-slate-800', 'text-blue-600', 'dark:text-blue-400');
      } else {
        link.classList.remove('bg-slate-100', 'dark:bg-slate-800', 'text-blue-600', 'dark:text-blue-400');
      }
    });
  }
  
  window.addEventListener('hashchange', filterAndHighlight);
  window.addEventListener('DOMContentLoaded', filterAndHighlight);
  
  const searchInput = document.getElementById('searchInput');
  if (searchInput) {
    searchInput.addEventListener('input', filterAndHighlight);
  }
  
  // ========== QQ 头像更换 ==========
  const qqAvatar = document.getElementById('qqAvatar');
  if (qqAvatar) {
    qqAvatar.addEventListener('click', () => {
      const newQQ = prompt('请输入新的QQ号码', '949022711');
      if (newQQ && /^\d{5,11}$/.test(newQQ)) {
        const qqAvatar = document.getElementById('qqAvatar') as HTMLImageElement | null;
        if (qqAvatar) {
          qqAvatar.src = `https://q1.qlogo.cn/g?b=qq&nk=${newQQ}&s=100`;
        }
      } else if (newQQ) {
        alert('请输入有效的QQ号码（5-11位数字）');
      }
    });
  }
  
  // ========== 返回顶部按钮 ==========
  const backToTopBtn = document.getElementById('back-to-top');
  if (backToTopBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        backToTopBtn.classList.remove('opacity-0', 'invisible', 'translate-y-4');
        backToTopBtn.classList.add('opacity-100', 'visible', 'translate-y-0');
      } else {
        backToTopBtn.classList.add('opacity-0', 'invisible', 'translate-y-4');
        backToTopBtn.classList.remove('opacity-100', 'visible', 'translate-y-0');
      }
    });
  }
  
  // ========== 每日美句 ==========
  const quoteEl = document.getElementById('dailyQuote');
  if (quoteEl) {
    quoteEl.textContent = '✨ 加载中...';
    fetch('https://v1.hitokoto.cn/')
      .then(res => res.json())
      .then(data => {
        quoteEl.textContent = `「${data.hitokoto}」${data.from ? ` —— 《${data.from}》` : ''}`;
      })
      .catch(() => {
        quoteEl.textContent = '✨ 长风破浪会有时，直挂云帆济沧海。';
      });
  }
</script>

<style>
  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
</style>
  </body>
</html>