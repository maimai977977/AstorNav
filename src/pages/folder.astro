---
import FolderLayout from '../layouts/FolderLayout.astro';
import roomData from '../data/roomdata.json';

interface NavItem {
  id: number;
  category: string;
  title: string;
  description: string;
  tags: string[];
  status: string;
  url: string;
  image: string;
}

const raw = roomData as NavItem[];
const folderMap = new Map<string, NavItem[]>();
raw.forEach(item => {
  const cat = item.category || '未分类';
  if (!folderMap.has(cat)) folderMap.set(cat, []);
  folderMap.get(cat)!.push(item);
});

const folders = Array.from(folderMap.entries())
  .map(([name, items]) => ({ name, items, count: items.length }))
  .sort((a, b) => b.count - a.count);

const total = raw.length;
const INITIAL_SHOW = 8;
const remaining = folders.slice(INITIAL_SHOW);
---

<FolderLayout title="文档导航">
  <div class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 py-6 max-w-6xl">
      <div class="flex items-center gap-4 mb-6 pb-4 border-b border-gray-200">
        <a href="/AstroNav/" class="text-gray-500 hover:text-blue-600 transition flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
          <span class="text-sm">返回</span>
        </a>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center shadow-md">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-6l-2-2H5a2 2 0 0 0-2 2z" /></svg>
          </div>
          <div>
            <h1 class="text-xl font-bold text-gray-800">文档导航</h1>
            <p class="text-xs text-gray-500">{total} 个资源 · {folders.length} 个分类</p>
          </div>
        </div>
      </div>

      <div class="mb-6 max-w-2xl mx-auto">
        <div class="relative">
          <input id="searchInput" type="text" placeholder="搜索资源..." class="w-full px-4 py-2.5 pl-10 rounded-xl bg-white border border-gray-300 focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 text-sm text-gray-800 placeholder-gray-400" />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0z" /></svg>
        </div>
      </div>

      <div id="folderList" class="space-y-2">
        {folders.slice(0, INITIAL_SHOW).map(folder => (
          <div class="folder-card bg-white rounded-xl border border-gray-200 overflow-hidden">
            <button onclick="toggleFolder(this)" class="w-full flex items-center gap-3 p-3 hover:bg-blue-50 transition-all group">
              <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center flex-shrink-0 shadow-sm">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-6l-2-2H5a2 2 0 0 0-2 2z" /></svg>
              </div>
              <div class="flex-1 text-left min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-semibold text-gray-800 truncate">{folder.name}</span>
                  <span class="text-xs text-gray-500 flex-shrink-0">({folder.count})</span>
                </div>
              </div>
              <div class="folder-icon transition-transform duration-300 text-gray-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </div>
            </button>
            <div class="folder-content hidden">
              <div class="px-3 pb-3 ml-11 border-l-2 border-gray-200">
                {folder.items.map(item => (
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 p-2 rounded-lg hover:bg-blue-50 transition-all group/link">
                    <div class="w-6 h-6 rounded bg-gray-100 flex items-center justify-center flex-shrink-0 overflow-hidden">
                      <img src={item.image || `https://www.google.com/s2/favicons?domain=${new URL(item.url).hostname}&sz=32`} class="w-4 h-4" onerror="this.style.display='none'" />
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2">
                        <span class="text-xs font-medium text-gray-700 group-hover/link:text-blue-600 truncate">{item.title}</span>
                        <span class={`w-1 h-1 rounded-full flex-shrink-0 ${item.status === 'online' ? 'bg-emerald-500' : 'bg-red-500'}`}></span>
                      </div>
                    </div>
                    <svg class="w-3 h-3 text-gray-400 group-hover/link:text-blue-500 group-hover/link:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      {remaining.length > 0 && (
        <div class="text-center mt-6">
          <button id="loadMoreBtn" class="px-6 py-2 bg-white border border-gray-300 hover:border-blue-400 hover:text-blue-600 rounded-lg text-sm text-gray-600 transition-all shadow-sm hover:shadow">
            加载更多分类
          </button>
        </div>
      )}

      <footer class="mt-8 pt-4 border-t border-gray-200 text-center text-xs text-gray-500">
        © MaiMaiNav 文档导航 · {folders.length} 个分类 · {total} 个资源数据仅供学习参考
          <br/>本站不储存、复制、传播任何文件 · 如有侵权请联系 <a href="mailto:maimai977977@gmail.com" class="text-blue-500 hover:text-blue-400 transition-colors">maimai977977@gmail.com</a>
      </footer>
    </div>
  </div>

<script define:vars={{ remaining: JSON.stringify(remaining) }}>
  const data = JSON.parse(remaining);
  let rendered = 0;
  const list = document.getElementById('folderList');
  const btn = document.getElementById('loadMoreBtn');

  window.toggleFolder = function(btn) {
    const card = btn.closest('.folder-card');
    const content = card.querySelector('.folder-content');
    const icon = card.querySelector('.folder-icon');
    const isHidden = content.classList.contains('hidden');
    if (isHidden) {
      content.classList.remove('hidden');
      icon.style.transform = 'rotate(90deg)';
    } else {
      content.classList.add('hidden');
      icon.style.transform = 'rotate(0deg)';
    }
  };

  if (btn) {
    btn.addEventListener('click', function() {
      const end = Math.min(rendered + 4, data.length);
      for (let i = rendered; i < end; i++) {
        const folder = data[i];
        let itemsHtml = '';
        folder.items.forEach(item => {
          const fav = item.image || ('https://www.google.com/s2/favicons?domain=' + new URL(item.url).hostname + '&sz=32');
          const dot = item.status === 'online' ? 'bg-emerald-500' : 'bg-red-500';
          itemsHtml += '<a href="' + item.url + '" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 p-2 rounded-lg hover:bg-blue-50 transition-all">' +
            '<div class="w-6 h-6 rounded bg-gray-100 flex items-center justify-center flex-shrink-0 overflow-hidden">' +
              '<img src="' + fav + '" class="w-4 h-4" onerror="this.style.display=\'none\'" />' +
            '</div>' +
            '<div class="flex-1 min-w-0">' +
              '<div class="flex items-center gap-2">' +
                '<span class="text-xs font-medium text-gray-700 truncate">' + item.title + '</span>' +
                '<span class="w-1 h-1 rounded-full flex-shrink-0 ' + dot + '"></span>' +
              '</div>' +
            '</div>' +
            '<svg class="w-3 h-3 text-gray-400 group-hover:text-blue-500 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>' +
          '</a>';
        });
        const div = document.createElement('div');
        div.className = 'folder-card bg-white rounded-xl border border-gray-200 overflow-hidden';
        div.innerHTML = '<button onclick="toggleFolder(this)" class="w-full flex items-center gap-3 p-3 hover:bg-blue-50 transition-all group">' +
          '<div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center flex-shrink-0 shadow-sm">' +
            '<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-6l-2-2H5a2 2 0 0 0-2 2z" /></svg>' +
          '</div>' +
          '<div class="flex-1 text-left min-w-0">' +
            '<div class="flex items-center gap-2">' +
              '<span class="text-sm font-semibold text-gray-800 truncate">' + folder.name + '</span>' +
              '<span class="text-xs text-gray-500 flex-shrink-0">(' + folder.count + ')</span>' +
            '</div>' +
          '</div>' +
          '<div class="folder-icon transition-transform duration-300 text-gray-400">' +
            '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>' +
          '</div>' +
        '</button>' +
        '<div class="folder-content hidden">' +
          '<div class="px-3 pb-3 ml-11 border-l-2 border-gray-200">' +
            itemsHtml +
          '</div>' +
        '</div>';
        list.appendChild(div);
      }
      rendered = end;
      if (rendered >= data.length) btn.style.display = 'none';
    });
  }

  document.getElementById('searchInput')?.addEventListener('input', function() {
    const term = this.value.toLowerCase().trim();
    const cards = list.querySelectorAll('.folder-card');
    cards.forEach(card => {
      const links = card.querySelectorAll('.folder-content a');
      let hasMatch = false;
      links.forEach(link => {
        const title = link.querySelector('span')?.textContent?.toLowerCase() || '';
        const show = !term || title.includes(term);
        link.style.display = show ? '' : 'none';
        if (show) hasMatch = true;
      });
      card.style.display = (hasMatch || !term) ? '' : 'none';
    });
  });
</script>

<style is:global>
  .folder-content.hidden { display: none; }
</style>
</FolderLayout>
