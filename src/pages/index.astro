---
// src/pages/index.astro
import Layout from  '../layouts/Layout.astro';
import navData from '../data/Navdata.json';   // 请确保路径正确，或者 public/data 方式
// 提取所有分类（去重）
const categories = ['全部', ...new Set(navData.map(item => item.category))];
---
<Layout>
  <h1 class="text-3xl font-bold" id="currentCategory">全部</h1>

<script>
  function updateCategory() {
    const hash = decodeURIComponent(window.location.hash.slice(1) || '全部');
    const heading = document.getElementById('currentCategory');
    if (heading) heading.textContent = hash;
  }
  window.addEventListener('hashchange', updateCategory);
  window.addEventListener('DOMContentLoaded', updateCategory);
</script>
</Layout>